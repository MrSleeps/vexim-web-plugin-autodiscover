{
    "name": "mrsleeps/vexim-web-plugin-autodiscover",
    "description": "Autodiscover/Autoconfig plugin to support in VExim Web UI",
    "license": "GPL-3.0-only",
    "authors": [
        {
            "name": "Mr Sleeps"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/support": "^13.0",
        "jeremykendall/php-domain-parser": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "VEximweb\\Plugin\\Autodiscover\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "VEximweb\\Plugin\\Autodiscover\\Providers\\AutodiscoverServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "1.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
